{
  "name": "climateguard-ai",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "cd client && npx vite",
    "server:dev": "nodemon server/index.js",
    "build": "npm install && cd client && npm install && npx vite build",
    "start": "node server/index.js",
    "test": "node server/test_offline_agent.js",
    "lint": "eslint .",
    "dev:amd": "node scripts/start-amd.js qwen2.5:1.5b",
    "dev:amd72b": "OLLAMA_MODEL_OVERRIDE=qwen2.5:72b node scripts/start-amd.js qwen2.5:72b",
    "dev:amd7b": "node scripts/start-amd.js qwen2.5:7b",
    "ollama:setup": "bash scripts/setup-ollama.sh qwen2.5:1.5b",
    "ollama:setup72b": "bash scripts/setup-ollama.sh qwen2.5:72b",
    "ollama:check": "node scripts/check-ollama.js",
    "ollama:stop": "pkill -f 'ollama serve' 2>/dev/null || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.16.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "nodemon": "^3.1.14",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.5",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.0.10"
  }
}

# Copy this file to `.env` and fill in your API key.
# Do NOT commit your real `.env` file; it's ignored by .gitignore.

# ── Vercel Deployment ────────────────────────────────────────────────────────
# When deploying the frontend to Vercel, set this in your Vercel project's
# environment variables to the URL of your backend (e.g. your Railway URL).
# Example: VITE_API_URL=https://your-app.railway.app
# Leave empty to use same-origin (when backend serves the frontend).
VITE_API_URL=
# For weather tile overlays in the browser, use a Vercel env var named
# VITE_OPENWEATHER_API_KEY (or OPENWEATHER_API_KEY, which is also supported).
VITE_OPENWEATHER_API_KEY=

# Google API key with Geolocation API, Maps JavaScript API, and YouTube Data API v3 enabled
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
PORT=3000

# ── Weather & Climate APIs ────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here
NASA_FIRMS_API_KEY=your_nasa_firms_api_key_here
IQAIR_API_KEY=your_iqair_api_key_here

# ── Optional data sources ─────────────────────────────────────────────────────
UNSPLASH_API_KEY=your_unsplash_api_key_here

# ── AI Mode ───────────────────────────────────────────────────────────────────
# Set AI_MODE to one of: ollama | groq | offline
# - ollama: preferred default, local/AMD GPU via Ollama
# - groq:   free cloud LLM — get key at https://console.groq.com
# - offline: deterministic rule-based fallback (always works)
AI_MODE=ollama

# ── Groq (Free cloud AI) ──────────────────────────────────────────────────────
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
# Optional: change the model (default: llama3-8b-8192)
# Other fast options: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant
# ── AMD Developer Cloud / Ollama ──────────────────────────────────────────────
# AMD MI300X setup (192GB HBM3 — runs Qwen 2.5 72B at full precision):
#
#   1. SSH into your AMD Developer Cloud instance
#   2. Install ROCm: https://rocm.docs.amd.com/en/latest/
#   3. Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
#   4. Pull Qwen: ollama pull qwen2.5:72b
#   5. Serve publicly: OLLAMA_HOST=0.0.0.0 ollama serve
#   6. Set the vars below, then AI_MODE=ollama
#
OLLAMA_BASE_URL=http://YOUR_AMD_INSTANCE_IP:11434
OLLAMA_MODEL=qwen2.5:72b
